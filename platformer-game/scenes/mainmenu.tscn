[sub_resource type="GDScript" id="GDScript_cmhrf"]
script/source = "extends Node

@onready var mainbuttons: VBoxContainer = $MainButtons
@onready var options: Panel = $Options


func _ready():
	options.visible = false
	mainbuttons.visible = true

func _on_button_pressed() -> void:
	get_tree().quit()
	print (\"button 1 presst\")

func _on_button_3_pressed() -> void:
	get_tree().change_scene_to_file(\"res://scenes/Game Selector.tscn\")
	print (\"button 1 presst\")

func _on_Selector_pressed() -> void:
	get_tree().change_scene_to_file(\"res://scenes/Game Selector.tscn\")
	print (\"button 1 presst\")


func _on_button_2_pressed() -> void:
	print (\"button 2 presst\")
	mainbuttons.visible = false
	options.visible = true


func _on_back_pressed() -> void:
	get_tree().change_scene_to_file(\"res://scenes/mainmenu.tscn\")
"

